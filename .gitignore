# Build output
build/
**/build/
x64/
*.exe
*.lib
*.dll
*.pdb
*.ilk
*.exp
*.obj
*.iobj
*.ipdb

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt

# Visual Studio
*.vcxproj.user
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# Shader copies (generated by CMake post-build; source is cubism/Framework)
FrameworkShaders/

# Test output (rendered video/audio artifacts) — keep .gitkeep
tests/output/*
!tests/output/.gitkeep

# Generated render artifacts under tests/fixtures/ — MP4s, logs, temp staging dirs
# JSON manifests and Python render scripts are kept (authored assets, not generated)
tests/fixtures/**/*.mp4
tests/fixtures/**/*.log
tests/fixtures/**/_tmp_*/

# Scratch/review manifests (one-shots used during model authoring, not fixtures)
tests/manifests/

# Results
results/

# Render server job outputs
renders/

# Python virtual environment
.venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Logs
*.log

# Devcontainer temp files
.devcontainer/.gituser.tmp

# Motion backup/versioned drafts — active clips have no version suffix
assets/models/**/motions/*_v*.motion3.json
assets/models/**/motions/*_review.motion3.json

# OS artifacts
Thumbs.db
.DS_Store

# Local environment — generated after build, not committed
.env
