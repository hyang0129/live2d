# Path to the built live2d-render binary.
# Set this after running the cmake build steps in README.md.
#
# Linux default (after: cmake --preset linux && cmake --build --preset linux):
LIVE2D_RENDER_BIN=build/live2d-render
#
# Windows default (after: cmake --preset windows && cmake --build --preset windows):
# LIVE2D_RENDER_BIN=build/Release/live2d-render.exe
