{
  "name": "Live2D Avatar Renderer",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "settings": {
        "cmake.configureOnOpen": true,
        "cmake.generator": "Ninja",
        "cmake.buildDirectory": "${workspaceFolder}/build",
        "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
        "C_Cpp.default.cppStandard": "c++17",
        "files.associations": {
          "*.fx": "hlsl"
        }
      },
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools-extension-pack",
        "twxs.cmake",
        "vadimcn.vscode-lldb",
        "anthropic.claude-code"
      ]
    }
  },

  "runArgs": ["--device=/dev/dri"],

  "mounts": [
    // Persist CMake build cache across container rebuilds
    "source=live2d-build-cache,target=${containerWorkspaceFolder}/build,type=volume"
  ],

  // Runs on the HOST before container start — cleans stale VS Code Server
  // installs from Docker Desktop WSL root and captures git identity.
  "initializeCommand": ".devcontainer\\initialize.cmd",

  "postCreateCommand": ".devcontainer/post-create.sh",

  "remoteUser": "vscode"
}
